{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "~/*": ["./app/*"]
    }
  },
  "include": ["app", "react-router.config.ts", "vite.config.ts"],
  "exclude": ["node_modules", "build"]
}
